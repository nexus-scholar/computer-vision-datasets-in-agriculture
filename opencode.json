{
  "$schema": "https://opencode.ai/config.json",
  "permission": {
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "list": "allow",
    "skill": "allow",
    "task": "allow",
    "edit": "ask",
    "external_directory": "deny",
    "websearch": "allow",
    "webfetch": "allow",
    "bash": {
      "*": "ask",
      "git status*": "allow",
      "git diff*": "allow",
      "git log*": "allow",
      "git show*": "allow",
      "python scripts/research/audit_snowball_run.py*": "allow",
      "python scripts/research/prepare_screening_queue.py*": "allow",
      "uv run pytest*": "allow",
      "python -m pytest*": "allow",
      "git push*": "deny",
      "git reset --hard*": "deny",
      "git clean*": "deny",
      "rm -rf*": "deny",
      "Remove-Item * -Recurse*": "deny",
      "python scripts/research/screening_state.py*": "allow",
      "python scripts/research/prepare_screening_batch.py*": "allow",
      "python scripts/research/finalize_screening_batch.py*": "allow",
      "python scripts/research/check_research_repo.py*": "allow"
    }
  },
  "compaction": {
    "auto": true,
    "prune": true,
    "reserved": 12000
  },
  "watcher": {
    "ignore": [
      ".git/**",
      ".venv/**",
      "**/__pycache__/**",
      ".pytest_cache/**",
      "outputs/**/cache/**",
      "outputs/**/raw_seed_records/**",
      "data/raw/seed_papers/**/*.pdf",
      "data/raw/api_archives/**"
    ]
  },
  "agent": {
    "plan": {
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git status*": "allow",
          "git diff*": "allow",
          "git log*": "allow",
          "python scripts/research/audit_snowball_run.py*": "allow"
        }
      }
    },
    "build": {
      "permission": {
        "edit": "ask",
        "bash": {
          "*": "ask",
          "git push*": "deny",
          "git reset --hard*": "deny",
          "git clean*": "deny"
        }
      }
    }
  }
}
